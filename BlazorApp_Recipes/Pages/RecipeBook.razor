@page "/recipebook"
@using BlazorApp_Recipes.Data
@inject RecipeService Service
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Recipe book</PageTitle>

<h1>Recipe book</h1>

<p>Here you can see all your stored recipes.</p>

@if (recipes == null)
{
    <p><em>Loading...</em></p>
}
else if (!recipes.Any())
{
    <p><em>No recipes available.</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Servings</th>
                <th>Note</th>
                <th>Ingredients</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var recipe in recipes)
            {
                <tr>
                    <td>@recipe.Name</td>
                    <td>@recipe.Category</td>
                    <td>@recipe.Servings</td>
                    <td>@recipe.Note</td>
                    <td>@string.Join(", ", recipe.GetIngredients())</td>
                    <td>
                        <div class="d-flex">                          
                            <button class="btn btn-primary btn-sm me-1" data-bs-toggle="tooltip" title="Edit" @onclick="() => EditRecipe(recipe.Id)">
                                <i class="fas fa-pen"></i>
                            </button>
                            <div data-bs-toggle="tooltip" title="Delete">
                                <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal" @onclick="() => PrepareDelete(recipe.Id)">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>


    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this recipe?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal" @onclick="DeleteRecipe">Delete</button>
                </div>
            </div>
        </div>
    </div>
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast align-items-center text-bg-success border-0" id="deleteToast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex align-items-center">
                <img src="/images/a-toast.png" alt="Success" width="132" height="165" class="me-2 mt-1" />
                <div class="toast-body">
                    Recipe deleted successfully.
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>




    <script>
        function showDeleteToast() {
            var toastEl = document.getElementById('deleteToast');
            var toast = new bootstrap.Toast(toastEl);
            toast.show();
        }
    </script>
}

@code {
    private Recipe[]? recipes;
    protected override async Task OnInitializedAsync()
    {
        //Service.Init();
        recipes = (await Service.GetAllRecipesAsync()).ToArray();
    }

    private int recipeIdToDelete;
    void PrepareDelete(int id)
    {
        recipeIdToDelete = id;
    }
    async Task DeleteRecipe()
    {
        await Service.DeleteRecipeAsync(recipeIdToDelete);
        await JS.InvokeVoidAsync("showDeleteToast");
        recipes = (await Service.GetAllRecipesAsync()).ToArray();
        StateHasChanged();
    }

    void EditRecipe(int id)
    {
        Navigation.NavigateTo($"/edit/{id}");

    }

}


