@page "/edit/{id:int}"
@using BlazorApp_Recipes.Data
@inject RecipeService Service
@inject NavigationManager Navigation
@using Radzen
@using Radzen.Blazor


<PageTitle>Edit existing recipe</PageTitle>

@code {
    [Parameter]
    public int id { get; set; }
    List<string> unitTypes => Service.UnitTypes;

    private bool ShowSuccessPopupMessage = false;
    private bool ShowFailPopupMessage = false;

    private Recipe originalRecipe = new Recipe();
    private Recipe newRecipe = new Recipe();
    protected override async Task OnInitializedAsync()
    {
        originalRecipe = await Service.GetRecipeByIdAsync(id);

        Service.CopyRecipeData(originalRecipe, newRecipe);

    }

    List<string> CategoryType => Service.CategoryTypes;
    private IEnumerable<string> SortedItems => CategoryType.Where(item => item != "Other")
                                                                    .OrderBy(item => item)
                                                                    .Concat(CategoryType.Where(item => item == "Other"));

    private async Task EditRecipe()
    {
        if (ValidBeforeEditing())
        {
            try
            {
                await Service.UpdateRecipeAsync2(newRecipe);

                ShowSuccessPopupMessage = true;
                StateHasChanged();
                await Task.Delay(3000);
                ShowSuccessPopupMessage = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
            }
        }
        else
        {
            ShowFailPopupMessage = true;
            StateHasChanged();
            await Task.Delay(3000);
            ShowFailPopupMessage = false;
            StateHasChanged();
        }
    }

    private async Task HandleClickAddIngredient()
    {
        newRecipe.Ingredients.Add(new Ingredient());
    }
    private async Task HandleClickRemoveIngredient()
    {
        Ingredient lastIngredient = newRecipe.Ingredients[newRecipe.Ingredients.Count - 1];
        if (newRecipe.Ingredients.Count > 1)
            newRecipe.Ingredients.Remove(lastIngredient);
        else if (newRecipe.Ingredients.Count == 1)
        {
            newRecipe.Ingredients[0] = new Ingredient();
        }

    }
    private bool ValidBeforeEditing()
    {
        if (newRecipe.Name == null)
            return false;
        foreach (var ingredient in newRecipe.Ingredients)
            if (ingredient.Value == 0 || ingredient.Type == "")
                return false;
        return true;
    }
    private void GoBack()
    {
        Navigation.NavigateTo("/recipebook");
    }

}


<h1>Edit existing recipe</h1>

@if (newRecipe?.Ingredients?.Count <= 0)
{
    <p>Loading recipe form…</p>
}
else
{
    <EditForm Model="newRecipe" OnValidSubmit="EditRecipe">
        <DataAnnotationsValidator />
        <ValidationSummary />


        <div class="field">
            <label for="name">Name:</label>
            <InputText id="name" @bind-Value="newRecipe.Name" class="form-control" />
        </div>

        <div class="field">
            <label for="category">Category:</label>
            <select id="category" @bind="newRecipe.Category" class="form-control">
                @foreach (var item in SortedItems)
                {
                    <option value="@item">@item</option>
                }
            </select>
        </div>

        <div class="field">
            <label for="servings">Servings:</label>
            <InputNumber id="servings" @bind-Value="newRecipe.Servings" class="form-control" />
        </div>

        <div class="field">
            <label for="note">Note:</label>
            <InputText id="note" @bind-Value="newRecipe.Note" class="form-control" />
        </div>

        <div class="field">
            <label for="note">Ingredients:</label>
            @foreach (var ingredient in newRecipe.Ingredients)
            {
                <div class="input-row">
                    <InputNumber @bind-Value="ingredient.Value" class="form-control input-field" />
                    <RadzenDropDown Data="unitTypes" @bind-Value="ingredient.Unit" Placeholder="Select an option" />
                    <InputText @bind-Value="ingredient.Type" class="form-control input-field" placeholder="butter" />
                </div>
            }
        </div>

        <div class="d-flex justify-content-center mt-3">
            <h1></h1>
            <button type="button" class="btn btn-warning me-2" @onclick="HandleClickRemoveIngredient">(-) Need Less Ingredient</button>
            <button type="button" class="btn btn-warning" @onclick="HandleClickAddIngredient">(+) Need More Ingredient</button>
        </div>
        <h1></h1>
        <div class="mt-3">
            <button type="button" class="btn btn-secondary me-2" @onclick="GoBack">Back</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
        @if (ShowSuccessPopupMessage)
        {
            <div class="popup-success">Recipe was updated successfully!</div>
        }
        @if (ShowFailPopupMessage)
        {
            <div class="popup-fail">Recipe can not be updated! (Fill the Name and Ingredients fields.)</div>
        }



    </EditForm>

}


<style>
    .input-row {
        display: flex;
        gap: 10px; /* Adjust the gap between input fields as needed */
        margin-bottom: 10px; /* Add spacing between rows */
    }

    .input-field {
        flex: 1;
    }

    .field {
        margin-bottom: 15px; /* Add spacing between rows */
    }

    .popup-success {
        position: fixed;
        top: 10px; /* Position it near the top of the page */
        left: 50%; /* Center horizontally */
        transform: translateX(-50%); /* Adjust for perfect centering */
        background-color: #bd9100; /* Warm orange #FFA500 */
        color: #FFFFFF; /* White text for visibility */
        padding: 10px 20px;
        border-radius: 5px;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.2); /* Subtle shadow for depth */
        opacity: 1;
        transition: opacity 3s ease-in-out; /* Smooth fade-out effect */
        z-index: 1000; /* Ensure it stays on top */
        font-size: 0.9em; /* Smaller font size to make it compact */
    }
    .popup-fail {
        position: fixed;
        top: 10px; /* Position it near the top of the page */
        left: 50%; /* Center horizontally */
        transform: translateX(-50%); /* Adjust for perfect centering */
        background-color: #bd3300; /* Warm orange #FFA500 */
        color: #FFFFFF; /* White text for visibility */
        padding: 10px 20px;
        border-radius: 5px;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.2); /* Subtle shadow for depth */
        opacity: 1;
        transition: opacity 3s ease-in-out; /* Smooth fade-out effect */
        z-index: 1000; /* Ensure it stays on top */
        font-size: 0.9em; /* Smaller font size to make it compact */
    }

</style>
