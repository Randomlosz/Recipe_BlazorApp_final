@page "/details/{id:int}"
@using BlazorApp_Recipes.Data
@inject RecipeService Service
@inject NavigationManager Navigation

<PageTitle>Details of existing recipe</PageTitle>

@code {
    [Parameter]
    public int id { get; set; }
    private Recipe originalRecipe= new Recipe();
    private Recipe recipe = new Recipe();
    protected override async Task OnInitializedAsync()
    {
        originalRecipe = await Service.GetRecipeByIdAsync(id);
        recipe.Ingredients = Enumerable
            .Range(0, originalRecipe.Ingredients.Count)
            .Select(_ => new Ingredient())
            .ToList();
        Service.CopyRecipeData(originalRecipe, recipe);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/recipebook");
    }
    private void GoEdit(int id)
    {
        Navigation.NavigateTo($"/edit/{id}");
    }

    private void IncreaseServings()
    {
        recipe.Servings++;
        Recalculate();
    }
    private void DecreaseServings()
    {
        if (recipe.Servings > 1)
            recipe.Servings--;
        Recalculate();
    }
    private void Recalculate()
    {  

        double ratio = (double)recipe.Servings / (double)originalRecipe.Servings;
        int i = 0;
        foreach (var ingredient in recipe.Ingredients)
        {
            ingredient.Value = ratio * originalRecipe.Ingredients[i].Value;
            i++;
        }

    }

}

<h1>Details of existing recipe</h1>

@if (recipe?.Ingredients?.Count <= 0)
{
    <p>Loading recipe details…</p>
}
else
{
   <div class="card mt-3">
        <div class="card-header">
            <h4>@originalRecipe.Name</h4>
        </div>
        <div class="card-body">
            <p><strong>Category:</strong> @originalRecipe.Category</p>
            <p><strong>Servings:</strong> @originalRecipe.Servings</p>
            <p><strong>Note:</strong> @originalRecipe.Note</p>

            <h5>Ingredients</h5>
            <ul>
                @foreach (var ingredient in originalRecipe.Ingredients)
                {
                    <li>@ingredient.Value @ingredient.Unit @ingredient.Type</li>
                }
            </ul>

            <div class="mt-3">
                <button class="btn btn-secondary me-2" @onclick="GoBack">Back</button>
                <button class="btn btn-primary" @onclick="() =>GoEdit(id)">Editing</button>
            </div>
        </div>
    </div>
    <h1></h1>

    <div class="card mt-3">
        <div class="card-header">
            <h6>Recalculate ingredients</h6>
        </div>
        <div class="card-body">

            <div class="d-flex align-items-center mb-3 gap-3">
                <button class="btn btn-outline-secondary" @onclick="DecreaseServings">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <p class="mb-0 d-flex align-items-center"><strong>Servings:</strong>&nbsp;@recipe.Servings</p>
                <button class="btn btn-outline-secondary" @onclick="IncreaseServings">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
            <h5>Ingredients</h5>
            <ul>
                @foreach (var ingredient in recipe.Ingredients)
                {
                    <li>@ingredient.Value @ingredient.Unit @ingredient.Type</li>
                }
            </ul>
        </div>
    </div>

}


<style>
    .input-row {
        display: flex;
        gap: 10px; /* Adjust the gap between input fields as needed */
        margin-bottom: 10px; /* Add spacing between rows */
    }

    .input-field {
        flex: 1;
    }

    .field {
        margin-bottom: 15px; /* Add spacing between rows */
