@page "/shopping_assistant"
@using BlazorApp_Recipes.Data
@inject RecipeService RecipeService
@inject ShoppingListService ListService
@inject GroceryCatalogService CatalogService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@using Radzen
@using Radzen.Blazor

<PageTitle>Shopping Assistant</PageTitle>

<h1>Shopping Assistant</h1>

<p>Here you can find your shopping asssitant.</p>

<div style="text-align:center;">
    <img src="images/map.png" alt="Map" style="max-width:100%; height:auto;" />
</div>


@code {
    enum ShoppingMode
    {
        SelectList,
        Shopping,
        Finished
    }
    private ShoppingMode mode = ShoppingMode.SelectList;
    
    int ProgressValue =>(int)(((double)(currentSectionIndex + 1) / sections.Count) * 100);

    private List<ShoppingList> allLists = new();
    private ShoppingList? selectedList;

    private Dictionary<string, List<Ingredient>> sections = new();
    private int currentSectionIndex = 0;

    protected override async Task OnInitializedAsync()
    {
        allLists = await ListService.GetAllShoppingListsAsync();
    }
    private Dictionary<string, List<Ingredient>> BuildSectionsFromList(ShoppingList list)
    {
        var result = new Dictionary<string, List<Ingredient>>();

        foreach (var ingredient in list.Ingredients)
        {
            string type = ingredient.Type?.Trim().ToLower() ?? "";

            string? matchedSection = CatalogService.GroceryCatalog
                .FirstOrDefault(section =>
                    section.Value.Any(item =>
                        item.Trim().ToLower() == type))
                .Key;
           
            if (matchedSection == null) // Handle error
                matchedSection = "Other";


            if (!result.ContainsKey(matchedSection))
                result[matchedSection] = new List<Ingredient>();

            result[matchedSection].Add(ingredient);
        }

        return result;
    }


    bool CanStart => selectedList != null;

    async Task StartShopping()
    {
        // Use your conversion function
        sections = BuildSectionsFromList(selectedList);

        currentSectionIndex = 0;
        mode = ShoppingMode.Shopping;
    }


    void NextSection()
    {
        currentSectionIndex++;

        if (currentSectionIndex >= sections.Count)
        {
            mode = ShoppingMode.Finished;
        }
    }
}


<RadzenCard Style="padding: 30px; max-width: 800px; margin: auto;">

    @if (mode == ShoppingMode.SelectList)
    {
        <!-- STATE 1: SELECT SHOPPING LIST -->
        <div class="d-flex flex-column align-items-center mt-4">

            <RadzenDropDown Data="@allLists"
                            TextProperty="Name"
                            TValue="ShoppingList"
                            @bind-Value="selectedList"
                            Placeholder="Select a shopping list"
                            Style="width: 300px;" />

            <RadzenButton Text="Start Shopping"
                          Icon="play_arrow"
                          Style="margin-top: 20px;"
                          Click="@StartShopping"
                          Disabled="@(!CanStart)" />
        </div>
    }

    @if (mode == ShoppingMode.Shopping)
    {
        <!-- STATE 2: SECTION VIEW -->
        var currentsectionName = sections.Keys.ElementAt(currentSectionIndex);
        var items = sections[currentsectionName].Select(i => $"{i.Value} {i.Unit} {i.Type}").ToList();

        <div class="mt-3">

            <RadzenText TextStyle="TextStyle.H3" TextAlign="TextAlign.Center" Style="margin-left: 20px; color: #444"><strong>@currentsectionName</strong><br /> </RadzenText>

            <div class="d-flex flex-column align-items-center mt-3">
                @foreach (var item in items)
                {
                    <RadzenPanel Style="width: 300px; margin-bottom: 1px;">
                        <ChildContent>
                            <div style="padding: 2px; font-size: 1.0rem; display: flex;">
                                <RadzenCheckBox TValue="bool" />
                                <span style="margin-left: 8px;">@item</span>
                            </div>
                        </ChildContent>
                    </RadzenPanel>
                }
            </div>

            <!-- Progress Bar -->
            <div class="d-flex justify-content-center mb-4">
                <RadzenProgressBar Value="@ProgressValue"
                                   ShowValue="true"
                                   Style="width: 60%; height: 25px;" />
            </div>

            <!-- Confirm Button -->
            <div class="d-flex justify-content-center mt-4">
                <RadzenButton Text="Next Section"
                              Icon="arrow_forward"
                              Click="@NextSection"
                              Style="width: 200px;" />
            </div>
        </div>
    }

    @if (mode == ShoppingMode.Finished)
    {
        <!-- STATE 3: FINISHED -->
        <div class="d-flex flex-column align-items-center mt-5">
            <RadzenIcon Icon="check_circle" Style="font-size: 60px; color: green;" />
            <RadzenText TextStyle="TextStyle.H3" TextAlign="TextAlign.Center" Style="color: green;">
                Your Shopping Adventure Ended 🙂
            </RadzenText>
            <RadzenText TextStyle="TextStyle.H4" TextAlign="TextAlign.Center">
                You can go to the cashiers now!
            </RadzenText>

        </div>
    }

</RadzenCard>

